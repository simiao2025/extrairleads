#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🛡️ Guard Deploy: Executando verificações pre-push..."

# 1. Checagem de formatação e lint (Biome)
echo "🔍 Rodando Biome Linter..."
npx biome check src/
if [ $? -ne 0 ]; then
  echo "❌ Biome Check falhou. Por favor, corrija os erros de pureza e estilo (dica: rode 'npx @biomejs/biome check --write src/')."
  exit 1
fi

# 2. Checagem de Tipos (TypeScript)
echo "🔍 Rodando TypeScript Check..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript Check falhou. Por favor, corrija os erros de tipagem."
  exit 1
fi

# 3. Testes
echo "🔍 Rodando Testes Unitários..."
npm run test -- --run
if [ $? -ne 0 ]; then
  echo "❌ Testes falharam. Impeça o código quebrado de subir para a origin!"
  exit 1
fi

echo "✅ Todas as checagens passaram! Push liberado. 🚀"
